{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel.rs/refs/heads/master/schemas/tauri-schema.json",
  "productName": "TriConnect",
  "version": "1.0.0",
  "identifier": "com.triconnect.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TriConnect — P2P Mesh",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' tauri: ipc: http://ipc.localhost blob: data: https: wss: ws:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
